<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Resources.Resources.ShopName</title>
    <link href="@Url.Content("~/Content/Site.css")" rel="stylesheet" type="text/css" />
</head>
<body>
    <header class="site-header">
        <div class="shop-title">💎 @Resources.Resources.ShopName</div>
    </header>

    <nav class="site-nav">
        <ul>
            <li>@Html.ActionLink("🏠 " + Resources.Resources.Home, "Index", "Home")</li>
            <li>@Html.ActionLink("💎 " + Resources.Resources.Catalog, "Index", "Jewelries")</li>
            <li>@Html.ActionLink("📂 " + Resources.Resources.Categories, "Index", "Category")</li>
            <li>@Html.ActionLink("💬 Чат", "Index", "Chat")</li>
        </ul>
        <div class="lang-switcher">
            @Html.ActionLink("🇺🇦 UA", "Change", "Language", new { lang = "uk", returnUrl = Request.RawUrl }, new { })
            <span>|</span>
            @Html.ActionLink("🇬🇧 EN", "Change", "Language", new { lang = "en", returnUrl = Request.RawUrl }, new { })
            <span>|</span>
            @Html.ActionLink("🇫🇷 FR", "Change", "Language", new { lang = "fr", returnUrl = Request.RawUrl }, new { })
        </div>
    </nav>

    <div class="content-wrapper">
        @RenderBody()
    </div>

    <footer class="site-footer">
        <div class="footer-columns">
            <div class="footer-col">
                <h4>@Resources.Resources.AboutShop</h4>
                <p>@Resources.Resources.ShopName</p>
            </div>
            <div class="footer-col">
                <h4>@Resources.Resources.Contacts</h4>
                <p>Гусятин, вул. Стуса 2</p>
            </div>
            <div class="footer-col">
                <h4>@Resources.Resources.WorkHours</h4>
                <p>Пн–Пт: 9:00–18:00</p>
            </div>
        </div>
        <div class="footer-bottom">
            © @DateTime.Now.Year — @Resources.Resources.Rights
        </div>
    </footer>

    <script src="@Url.Content("~/Scripts/jquery-3.4.1.min.js")"></script>
    @RenderSection("scripts", required: false)
</body>
</html>