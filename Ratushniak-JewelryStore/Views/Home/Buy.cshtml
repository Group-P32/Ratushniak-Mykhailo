@{
    ViewBag.Title = "Оформлення покупки";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3>Форма оформлення покупки</h3>

<form method="post">
    <input type="hidden" value="@ViewBag.JewelryId" name="JewelryId" />
    <table style="width:auto; border:none; background:transparent;">
        <tr>
            <td style="border:none;"><p>Введіть своє ім'я та прізвище:</p></td>
            <td style="border:none;"><input type="text" name="Person" /></td>
        </tr>
        <tr>
            <td style="border:none;"><p>Введіть свою адресу:</p></td>
            <td style="border:none;"><input type="text" name="Address" /></td>
        </tr>
        <tr>
            <td style="border:none;">
                <input type="submit" value="Відправити" />
            </td>
            <td style="border:none;"></td>
        </tr>
    </table>
</form>

<br />
<a href="/Home/Index">← Повернутись до каталогу</a>