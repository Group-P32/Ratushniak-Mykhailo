@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Оформлення покупки — Срібна підкова</title>
</head>
<body>
    <div>
        <h3>Форма оформлення покупки</h3>
        <form method="post">
            <input type="hidden" value="@ViewBag.JewelryId" name="JewelryId" />
            <table>
                <tr>
                    <td><p>Введіть своє ім'я та прізвище:</p></td>
                    <td><input type="text" name="Person" /></td>
                </tr>
                <tr>
                    <td><p>Введіть свою адресу:</p></td>
                    <td><input type="text" name="Address" /></td>
                </tr>
                <tr>
                    <td><input type="submit" value="Відправити" /></td>
                    <td></td>
                </tr>
            </table>
        </form>
        <br />
        <a href="/Home/Index">← Повернутись до каталогу</a>
    </div>
</body>
</html>