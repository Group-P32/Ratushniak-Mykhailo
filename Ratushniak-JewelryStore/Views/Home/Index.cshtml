@using JewelryStore.Models
@using Ratushniak_JewelryStore.Helpers
@model JewelryStore.Models.JewelryListViewModel
@{
    ViewBag.Title = Resources.Resources.Catalog;
}
<h2>@Resources.Resources.Catalog</h2>
@using (Html.BeginForm("Index", "Home", FormMethod.Get))
{
    <div class="filter-panel">
        <label>@Resources.Resources.Category:</label>
        @Html.DropDownList("categoryId", Model.Categories, Resources.Resources.AllCategories, new { @class = "filter-select" })
        <label>@Resources.Resources.Price:</label>
        @Html.TextBox("minPrice", Model.MinPrice, new { placeholder = "від", @class = "filter-input" })
        —
        @Html.TextBox("maxPrice", Model.MaxPrice, new { placeholder = "до", @class = "filter-input" })
        <button type="submit" class="btn-filter">@Resources.Resources.Filter</button>
        @Html.ActionLink(Resources.Resources.Reset, "Index", "Home", null, new { @class = "btn-reset" })
    </div>
}
<table class="jewelry-table">
    <thead>
        <tr>
            <th>@Resources.Resources.Name</th>
            <th>@Resources.Resources.Type</th>
            <th>@Resources.Resources.Material</th>
            <th>@Resources.Resources.Weight</th>
            <th>@Resources.Resources.Price</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Jewelries)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Type</td>
                <td>@item.Material</td>
                <td>@item.Weight г</td>
                <td>@item.Price грн</td>
                <td>@Html.ActionLink(Resources.Resources.Buy, "Buy", "Home", new { id = item.Id }, new { @class = "btn-buy" })</td>
            </tr>
        }
    </tbody>
</table>
<div class="search-panel">
    <h3>🔍 @Resources.Resources.Name / @Resources.Resources.Material</h3>
    <input type="text" id="searchQuery" placeholder="Введіть назву або матеріал..." class="filter-input" style="width:300px;" />
    <button onclick="doSearch()" class="btn-filter">Пошук</button>
    <div id="searchResults" style="margin-top:15px;"></div>
</div>
@Html.PageLinks(Model.PageInfo, x => Url.Action("Index", "Home", new { page = x, categoryId = Model.SelectedCategoryId, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice }))
@section scripts {
<script src="@Url.Content("~/Scripts/jquery-1.10.2.min.js")"></script>
    <script>
        function doSearch() {
            var query = $('#searchQuery').val();
            if (query.length < 1) {
                $('#searchResults').html('');
                return;
            }
            $.ajax({
                url: '@Url.Action("Search", "Home")',
                type: 'GET',
                data: { query: query },
                success: function (result) {
                    $('#searchResults').html(result);
                },
                error: function () {
                    $('#searchResults').html('<p style="color:red;">Помилка пошуку.</p>');
                }
            });
        }

        $('#searchQuery').on('keyup', function () {
            doSearch();
        });
    </script>
}