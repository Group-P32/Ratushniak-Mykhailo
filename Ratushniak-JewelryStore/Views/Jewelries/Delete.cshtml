@model JewelryStore.Models.Jewelry
@{
    ViewBag.Title = "Видалення прикраси";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3>Видалення прикраси</h3>
<p>Ви впевнені, що хочете видалити цю прикрасу?</p>

<table>
    <tr class="header">
        <td>Поле</td>
        <td>Значення</td>
    </tr>
    <tr>
        <td>Назва</td>
        <td>@Html.DisplayFor(m => m.Name)</td>
    </tr>
    <tr>
        <td>Тип</td>
        <td>@Html.DisplayFor(m => m.Type)</td>
    </tr>
    <tr>
        <td>Матеріал</td>
        <td>@Html.DisplayFor(m => m.Material)</td>
    </tr>
    <tr>
        <td>Вага (г)</td>
        <td>@Html.DisplayFor(m => m.Weight)</td>
    </tr>
    <tr>
        <td>Ціна (грн)</td>
        <td>@Html.DisplayFor(m => m.Price)</td>
    </tr>
</table>

<br />
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <input type="submit" value="Видалити" style="background-color:#8b0000; color:white; padding:8px 20px; border:none; cursor:pointer;" />
}
<p>@Html.ActionLink("← Скасувати і повернутись", "Index")</p>