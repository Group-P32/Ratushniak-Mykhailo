@model IEnumerable<JewelryStore.Models.Jewelry>
@{
    ViewBag.Title = "Список прикрас";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3>Список прикрас</h3>
<p>@Html.ActionLink("Додати нову прикрасу", "Create")</p>

<table>
    <tr class="header">
        <td>Назва</td>
        <td>Тип</td>
        <td>Матеріал</td>
        <td>Вага (г)</td>
        <td>Ціна (грн)</td>
        <td>Категорія</td>
        <td></td>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Name)</td>
            <td>@Html.DisplayFor(modelItem => item.Type)</td>
            <td>@Html.DisplayFor(modelItem => item.Material)</td>
            <td>@Html.DisplayFor(modelItem => item.Weight)</td>
            <td>@Html.DisplayFor(modelItem => item.Price)</td>
            <td>@(item.Category != null ? item.Category.Name : "—")</td>
            <td>
                @Html.ActionLink("Редагувати", "Edit", new { id = item.Id }) |
                @Html.ActionLink("Деталі", "Details", new { id = item.Id }) |
                @Html.ActionLink("Видалити", "Delete", new { id = item.Id })
            </td>
        </tr>
    }
</table>